{
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "envmcp",
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "envmcp",
        "npx",
        "-y",
        "firecrawl-mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  }
}